{
  "entities": {
    "Pyq": {
      "title": "Previous Year Question",
      "description": "Collection of previous year examination papers.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "departmentId": { "type": "string" },
        "semester": { "type": "number" },
        "year": { "type": "number" },
        "type": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "storagePath": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "views": { "type": "number" },
        "likes": { "type": "number" }
      },
      "required": ["title", "departmentId", "semester", "pdfUrl", "createdAt"]
    },
    "Note": {
      "title": "Study Note",
      "description": "Student or teacher contributed study notes.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "departmentId": { "type": "string" },
        "semester": { "type": "number" },
        "author": { "type": "string" },
        "pdfUrl": { "type": "string" },
        "storagePath": { "type": "string" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "views": { "type": "number" },
        "likes": { "type": "number" }
      },
      "required": ["title", "departmentId", "semester", "pdfUrl", "author", "createdAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Sitewide news and updates.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "createdAt"]
    }
  },
  "firestore": {
    "pyqs/{pyqId}": {
      "schema": "Pyq",
      "description": "Stores paper metadata."
    },
    "notes/{noteId}": {
      "schema": "Note",
      "description": "Stores note metadata."
    },
    "announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Stores sitewide updates."
    }
  }
}
