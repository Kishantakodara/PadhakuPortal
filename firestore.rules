rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core collections: Public read access
    match /announcements/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'kishantakodara4@gmail.com';
    }
    
    match /pyqs/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'kishantakodara4@gmail.com';
    }
    
    match /notes/{id} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'kishantakodara4@gmail.com';
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
