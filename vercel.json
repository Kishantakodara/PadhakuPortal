{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/privacy-policy",
      "destination": "/privacypolicy",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/nvidia/:path*",
      "destination": "https://integrate.api.nvidia.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
